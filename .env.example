# ─────────────────────────────────────────────────────────────
# ZATCA Middleware — Business Central edition
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────

# ===== REQUIRED: Supabase (your new database project) =====
# Supabase Dashboard > Project Settings > Data API  (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Supabase Dashboard > Project Settings > API Keys > anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Supabase Dashboard > Project Settings > API Keys > service_role key (KEEP SECRET — server only)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ===== OPTIONAL: app =====
# Public site URL (used for absolute links / redirects). Local dev default below.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== OPTIONAL: "Bank Product" portal (only if you use that login flow) =====
# Secret used to sign bank-portal session cookies. Set any long random string in production.
# BANK_SESSION_SECRET=change-me-to-a-long-random-string
# Allow seeded demo users outside development:
# EGS_ENABLE_DEMO_USERS=false
# Pre-wire the bank portal to a middleware tenant (optional):
# EGS_MIDDLEWARE_BASE_URL=http://localhost:3000
# EGS_MIDDLEWARE_API_KEY=
# EGS_MIDDLEWARE_BANK_NAME=

# ─────────────────────────────────────────────────────────────
# NOTE: Business Central credentials (Tenant ID, Client ID/Secret,
# Company GUID, Environment) are NOT set here. They are entered per
# organization in the app at  Admin > Business Central Settings
# and stored in the `bc_config` table.
# ─────────────────────────────────────────────────────────────
